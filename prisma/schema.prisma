generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════════════════════════

model User {
  id        String   @id          // = Clerk user ID (user_...)
  email     String   @unique
  prenom    String?
  nom       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gardes   Garde[]
  familles Famille[]
  nounous  Nounou[]
}

// ═══════════════════════════════════════════════════════════════
// GARDE
// ═══════════════════════════════════════════════════════════════

model Garde {
  id     String  @id @default(cuid())
  nom    String?
  statut String  @default("brouillon") // 'brouillon' | 'actif' | 'archivé'

  proprietaireId String
  proprietaire   User   @relation(fields: [proprietaireId], references: [id])

  // Lien de partage générique : rejoint par Famille B et/ou la nounou
  // (chacun se déclare sur /rejoindre), donne accès en lecture/écriture.
  invitationToken          String?
  invitationTokenExpiresAt DateTime?

  publicTokenNounou String?

  congesJson String? // JSON: CongesConfig

  // Renseigné quand cette garde a été archivée suite à une mise à jour de
  // paie ayant des conséquences rétroactives (cf. fork-ou-update Settings).
  archiveeVersGardeId String? @unique
  archiveeVersGarde   Garde?  @relation("GardeArchivage", fields: [archiveeVersGardeId], references: [id])
  archiveeDepuisGarde Garde?  @relation("GardeArchivage")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nounou   Nounou?
  familles Famille[]
  enfants  Enfant[]
  modele   Modele?
  mois     Mois[]
}

model Nounou {
  id      String  @id @default(cuid())
  gardeId String  @unique
  garde   Garde   @relation(fields: [gardeId], references: [id], onDelete: Cascade)
  prenom  String
  nom     String?
  email   String?

  // Renseigné quand la nounou rejoint la garde via le lien de partage
  utilisateurId String?
  utilisateur   User?   @relation(fields: [utilisateurId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Famille {
  id           String  @id @default(cuid())
  gardeId      String
  garde        Garde   @relation(fields: [gardeId], references: [id], onDelete: Cascade)
  label        String  // 'A' | 'B'
  nomAffiche   String?
  emailContact String?
  // 'proprietaire' | 'invite_actif' | 'invite_en_attente'
  statutAcces  String  @default("invite_en_attente")

  utilisateurId String?
  utilisateur   User?   @relation(fields: [utilisateurId], references: [id])

  // Aides CAF / fiscales (mode EQUITABLE)
  cmgCotisations    Float @default(0)
  cmgRemuneration   Float @default(0)
  abattementCharges Float @default(0)
  aideVille         Float @default(0)
  creditImpot       Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gardeId, label])
}

model Enfant {
  id      String @id @default(cuid())
  gardeId String
  garde   Garde  @relation(fields: [gardeId], references: [id], onDelete: Cascade)
  prenom  String
  fam     String // 'A' | 'B'

  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// MODÈLE DE PLANNING & PAIE
// ═══════════════════════════════════════════════════════════════

model Modele {
  id      String @id @default(cuid())
  gardeId String @unique
  garde   Garde  @relation(fields: [gardeId], references: [id], onDelete: Cascade)

  hNormalesSemaine        Float  @default(40)
  hSup25Semaine           Float  @default(0)   // heures 40-48h/sem (+25%)
  hSup50Semaine           Float  @default(0)   // heures >48h/sem  (+50%)

  // 'A.1' | 'B.1' | 'A.2' | 'B.2' (legacy — kept for compat)
  modeCalcul      String  @default("A.1")
  repartitionA    Float   @default(0.5)
  racOptionActive Boolean @default(false)

  tauxHoraireNet Float @default(11)

  navigoMontant     Float @default(90.80)
  indemKm           Float @default(0)
  indemEntretien    Float @default(6.0)
  repartitionIndemA Float @default(0.5)  // part famille A sur les indemnités (navigo, km, entretien)

  // JSON : { "1": { actif, hDebut, hFin }, ... }  clés 1=lun..5=ven
  joursJson String @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// MOIS
// ═══════════════════════════════════════════════════════════════

model Mois {
  id      String @id @default(cuid())
  gardeId String
  garde   Garde  @relation(fields: [gardeId], references: [id], onDelete: Cascade)

  annee  Int
  mois   Int
  // 'ouvert' | 'valide_a' | 'valide_b' | 'valide_ab'
  statut String @default("ouvert")

  evenementsJson String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gardeId, annee, mois])
}
